{
  "name": "@versionzero/configurator",
  "version": "0.2.1-main.19",
  "description": "A simple configuration utility for Node.js",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./sources": "./src/configuration-sources/index.js",
    "./utils": "./src/utils.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/argh/configurator.git"
  },
  "keywords": [
    "configuration",
    "schema",
    "command line",
    "configurator",
    "argh",
    "versionzero",
    "v0"
  ],
  "author": "argh",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.22.0",
    "tsc": ">=5.5"
  },
  "scripts": {
    "test": "mocha --timeout 0 --ui bdd --recursive --exit",
    "test:coverage": "c8 mocha --timeout 0 --ui bdd --recursive --exit",
    "docs:api": "typedoc",
    "docs:api:json": "typedoc --json docs-output/api.json",
    "docs:api:contributors": "typedoc --excludeInternal false --excludePrivate false --out docs-output-contributors",
    "docs:api:contributors:json": "typedoc --excludeInternal false --excludePrivate false --json docs-output-contributors/api.json",
    "docs:api:md": "typedoc --options typedoc-md.json",
    "docs:api:md:contributors": "typedoc --options typedoc-md.json --excludeInternal false --excludePrivate false --out docs-output-md-contributors"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.10",
    "c8": "^8.0.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.5.4",
    "mocha": "^10.2.0",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "~5.8"
  }
}
