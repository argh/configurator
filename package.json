{
  "name": "@versionzero/configurator",
  "version": "0.9.0-main.0",
  "description": "A simple configuration utility for Node.js",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "default": "./src/index.js",
      "types": "./types/index.d.ts"
    },
    "./helpers": {
      "default": "./src/helpers.js",
      "types": "./types/helpers.d.ts"
    },
    "./sources": {
      "default": "./src/configuration-sources/index.js",
      "types": "./types/configuration-sources/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/argh/configurator.git"
  },
  "keywords": [
    "configuration",
    "schema",
    "command line",
    "configurator",
    "argh",
    "versionzero",
    "v0"
  ],
  "author": "Jolly Roger <argh@v0.net> (https://github.com/argh)",  
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.9.0",
    "tsc": ">=5.5"
  },
  "scripts": {
    "build:types": "tsc --declaration --emitDeclarationOnly",
    "test": "mocha --timeout 0 --ui bdd --recursive --exit",
    "test:bail": "mocha -b --timeout 0 --ui bdd --recursive --exit",
    "test:coverage": "c8 mocha --timeout 0 --ui bdd --recursive --exit --ignore 'test/99-*.test.js'",
    "docs:api": "typedoc",
    "docs:api:json": "typedoc --json docs-output/api.json",
    "docs:api:contributors": "typedoc --excludeInternal false --excludePrivate false --out docs-output-contributors",
    "docs:api:contributors:json": "typedoc --excludeInternal false --excludePrivate false --json docs-output-contributors/api.json",
    "docs:api:md": "typedoc --options typedoc-md.json",
    "docs:api:md:contributors": "typedoc --options typedoc-md.json --excludeInternal false --excludePrivate false --out docs-output-md-contributors"
  },
  "peerDependencies": {
    "@versionzero/schema": ">=0.9.0-main.0"
  },
  "devDependencies": {
    "@versionzero/schema": ">=0.9.0-main.0",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.10",
    "c8": "^8.0.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.5.4",
    "mocha": "^11.7.4",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "typedoc-plugin-missing-exports": "^4.1.2",
    "typescript": "~5.8"
  }
}
