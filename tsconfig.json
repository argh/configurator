{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["es2023", "esnext.iterator"],
    "checkJs": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "types": ["node", "mocha"],
    "useUnknownInCatchVariables": false,

    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "types",
    //"declarationMap": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "test",
    "examples",
    "coverage",
    "docs-output",
    "docs-output-contributors",
    ".c8",
    "benchmark",
    "scripts",
    "dev-scripts"
  ]
}
