name: CI/CD Pipeline

on:
  push:
    branches:
      - '**'
  pull_request:
    branches:
      - main
      - release
      - 'hotfix-*'

jobs:
  build-and-publish:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITHUB_TOKEN }}

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          registry-url: 'https://registry.npmjs.org'

      - name: Extract package info
        id: package-info
        run: |
          echo "name=$(node -p "require('./package.json').name")" >> $GITHUB_OUTPUT
          echo "version=$(node -p "require('./package.json').version")" >> $GITHUB_OUTPUT
          echo "private=$(node -p "require('./package.json').private || false")" >> $GITHUB_OUTPUT
          echo "scope=$(node -p "const name = require('./package.json').name; name.startsWith('@') ? name.split('/')[0] : ''")" >> $GITHUB_OUTPUT

      - name: Determine registry configuration
        id: registry-config
        run: |
          PACKAGE_SCOPE="${{ steps.package-info.outputs.scope }}"
          REPO_OWNER="@${{ github.repository_owner }}"
          IS_PRIVATE="${{ steps.package-info.outputs.private }}"
          BRANCH="${{ github.ref_name }}"
          
          # Determine where this package will be published
          if [[ "$PACKAGE_SCOPE" == "$REPO_OWNER" ]]; then
            echo "target=ghcr" >> $GITHUB_OUTPUT
            echo "registry=https://npm.pkg.github.com" >> $GITHUB_OUTPUT
          elif [[ ("$BRANCH" == "release" || "$BRANCH" == hotfix-*) && "$IS_PRIVATE" == "false" ]]; then
            echo "target=npm" >> $GITHUB_OUTPUT
            echo "registry=https://registry.npmjs.org" >> $GITHUB_OUTPUT
          else
            echo "target=verdaccio" >> $GITHUB_OUTPUT
            echo "registry=${{ secrets.VERDACCIO_URL }}" >> $GITHUB_OUTPUT
          fi
          
          # Determine npm dist-tag for publishing
          if [[ "$BRANCH" == "release" ]]; then
            echo "tag=latest" >> $GITHUB_OUTPUT
          else
            CLEAN_BRANCH=$(echo "$BRANCH" | sed 's/[^a-zA-Z0-9-]/-/g')
            echo "tag=${CLEAN_BRANCH}-latest" >> $GITHUB_OUTPUT
          fi

      - name: Configure npm authentication
        run: |
          # Start with a clean .npmrc
          echo "" > ~/.npmrc
          
          # If using Verdaccio as primary registry, set it as default
          if [[ "${{ steps.registry-config.outputs.target }}" == "verdaccio" ]]; then
            echo "registry=${{ secrets.VERDACCIO_URL }}" >> ~/.npmrc
            VERDACCIO_HOST=$(echo "${{ secrets.VERDACCIO_URL }}" | sed 's|https\?://||' | sed 's|/$||')
            echo "//${VERDACCIO_HOST}/:_authToken=${{ secrets.VERDACCIO_TOKEN }}" >> ~/.npmrc
          fi
          
          # Configure GitHub Packages for @repo-owner scope
          echo "//npm.pkg.github.com/:_authToken=${{ secrets.GITHUB_TOKEN }}" >> ~/.npmrc
          echo "@${{ github.repository_owner }}:registry=https://npm.pkg.github.com" >> ~/.npmrc
          
          # If package scope is different from repo owner and Verdaccio is configured,
          # route that scope through Verdaccio
          PACKAGE_SCOPE="${{ steps.package-info.outputs.scope }}"
          if [[ -n "$PACKAGE_SCOPE" && "$PACKAGE_SCOPE" != "@${{ github.repository_owner }}" && -n "${{ secrets.VERDACCIO_URL }}" ]]; then
            echo "${PACKAGE_SCOPE}:registry=${{ secrets.VERDACCIO_URL }}" >> ~/.npmrc
          fi
          
          # Configure NPM registry auth if token provided (for publishing)
          if [[ -n "${{ secrets.NPM_TOKEN }}" ]]; then
            echo "//registry.npmjs.org/:_authToken=${{ secrets.NPM_TOKEN }}" >> ~/.npmrc
          fi
          cat ~/.npmrc
      - name: Cache dependencies
        uses: actions/cache@v3
        with:
          path: ~/.npm
          key: ${{ runner.os }}-node-${{ hashFiles('**/package-lock.json') }}
          restore-keys: |
            ${{ runner.os }}-node-

      - name: Install dependencies
        run: npm ci

      - name: Run tests
        run: npm test --if-present

      - name: Build
        run: npm run build --if-present

      - name: Extract package info
        id: package
        run: |
          echo "name=${{ steps.package-info.outputs.name }}" >> $GITHUB_OUTPUT
          echo "version=${{ steps.package-info.outputs.version }}" >> $GITHUB_OUTPUT
          echo "private=${{ steps.package-info.outputs.private }}" >> $GITHUB_OUTPUT
          echo "scope=${{ steps.package-info.outputs.scope }}" >> $GITHUB_OUTPUT

      - name: Determine publishing target
        id: publish-target
        run: |
          echo "target=${{ steps.registry-config.outputs.target }}" >> $GITHUB_OUTPUT
          echo "registry=${{ steps.registry-config.outputs.registry }}" >> $GITHUB_OUTPUT
          echo "tag=${{ steps.registry-config.outputs.tag }}" >> $GITHUB_OUTPUT

      - name: Configure git
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"

      - name: Determine version bump
        id: version
        run: |
          BRANCH="${{ github.ref_name }}"
          CURRENT_VERSION="${{ steps.package.outputs.version }}"
          
          if [[ "$BRANCH" == "release" ]]; then
            # For release branches, bump patch version and remove prerelease
            NEW_VERSION=$(npm version patch --no-git-tag-version)
            echo "is_release=true" >> $GITHUB_OUTPUT
          else
            # For all other branches (including hotfix), bump prerelease with branch name
            # Clean branch name for valid semver
            CLEAN_BRANCH=$(echo "$BRANCH" | sed 's/[^a-zA-Z0-9-]/-/g')
          
            # Check if current version has prerelease for this branch
            if [[ "$CURRENT_VERSION" == *"-$CLEAN_BRANCH."* ]]; then
              # Increment existing prerelease
              NEW_VERSION=$(npm version prerelease --preid="$CLEAN_BRANCH" --no-git-tag-version)
            else
              # Start new prerelease
              NEW_VERSION=$(npm version prepatch --preid="$CLEAN_BRANCH" --no-git-tag-version)
            fi
            echo "is_release=false" >> $GITHUB_OUTPUT
          fi
          
          echo "new_version=${NEW_VERSION#v}" >> $GITHUB_OUTPUT

      - name: Update CHANGELOG for release
        if: steps.version.outputs.is_release == 'true'
        run: |
          VERSION="${{ steps.version.outputs.new_version }}"
          DATE=$(date +%Y-%m-%d)
          
          # Create CHANGELOG entry
          ENTRY="## [$VERSION] - $DATE\n\n### Changes\n"
          
          # Get commit messages since last tag
          LAST_TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo "")
          if [[ -n "$LAST_TAG" ]]; then
            COMMITS=$(git log --pretty=format:"- %s (%h)" "$LAST_TAG"..HEAD)
          else
            COMMITS=$(git log --pretty=format:"- %s (%h)")
          fi
          
          ENTRY="${ENTRY}${COMMITS}\n\n"
          
          # Update or create CHANGELOG.md
          if [[ -f CHANGELOG.md ]]; then
            # Insert after header
            awk -v entry="$ENTRY" 'NR==1{print; print ""; print entry} NR>1' CHANGELOG.md > CHANGELOG.tmp
            mv CHANGELOG.tmp CHANGELOG.md
          else
            echo -e "# Changelog\n\nAll notable changes to this project will be documented in this file.\n\n$ENTRY" > CHANGELOG.md
          fi
          
          # Commit changes
          git add CHANGELOG.md package.json package-lock.json
          git commit -m "chore(release): $VERSION [skip ci]"
          git tag "v$VERSION"

      - name: Publish to registry
        env:
          NODE_AUTH_TOKEN: ${{ steps.publish-target.outputs.target == 'npm' && secrets.NPM_TOKEN || secrets.GITHUB_TOKEN }}
        run: |
          echo "Publishing to ${{ steps.publish-target.outputs.target }} registry..."
          echo "Using dist-tag: ${{ steps.publish-target.outputs.tag }}"
          npm publish --registry ${{ steps.publish-target.outputs.registry }} --tag ${{ steps.publish-target.outputs.tag }}

      - name: Push changes
        if: steps.version.outputs.is_release == 'true'
        run: |
          git push origin HEAD:${{ github.ref_name }}
          git push origin --tags

      - name: Create GitHub Release
        if: steps.version.outputs.is_release == 'true'
        uses: actions/create-release@v1
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          tag_name: v${{ steps.version.outputs.new_version }}
          release_name: Release ${{ steps.version.outputs.new_version }}
          body: |
            See [CHANGELOG.md](CHANGELOG.md) for details.
          draft: false
          prerelease: false